{
  "name": "nestjs-boilerplate",
  "version": "1.0.0",
  "description": "NestJS + MikroORM starter with PostgreSQL/MySQL switch support and optional Redis.",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "npm run quality:check",
    "build": "npm run build:app",
    "build:app": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node tools/run-command-with-db.js nest start",
    "start:dev": "node tools/run-command-with-db.js nest start --watch",
    "start:debug": "node tools/run-command-with-db.js nest start --debug --watch",
    "start:prod": "node tools/run-command-with-db.js node dist/main.js",
    "setup:profile": "node tools/setup-profile.js",
    "lint": "eslint --config .eslintrc.js --ext .ts src test --fix",
    "lint:check": "eslint --config .eslintrc.js --ext .ts src test --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "quality:check": "npm run typecheck && npm run lint:check && npm run test",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --runInBand",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migration:create": "node tools/run-command-with-db.js mikro-orm migration:create",
    "db:migration:up": "node tools/run-command-with-db.js mikro-orm migration:up",
    "db:migration:down": "node tools/run-command-with-db.js mikro-orm migration:down",
    "db:seeder:create": "node tools/run-command-with-db.js mikro-orm seeder:create",
    "db:seed": "node tools/run-command-with-db.js mikro-orm seeder:run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.937.0",
    "@aws-sdk/s3-request-presigner": "^3.842.0",
    "@mikro-orm/cli": "6.2.9",
    "@mikro-orm/core": "6.2.9",
    "@mikro-orm/migrations": "6.2.9",
    "@mikro-orm/mysql": "6.2.9",
    "@mikro-orm/nestjs": "6.1.2",
    "@mikro-orm/postgresql": "6.2.9",
    "@mikro-orm/reflection": "6.2.9",
    "@mikro-orm/seeder": "6.2.9",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.13.2",
    "bullmq": "^5.41.2",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.2.2",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "mustache": "^4.2.0",
    "mysql2": "^3.11.4",
    "nestjs-keycloak-auth": "^1.0.5",
    "nodemailer": "^7.0.7",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "sql-formatter": "^15.4.5",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/mustache": "^4.2.6",
    "@types/node": "^20.17.17",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "mikro-orm": {
    "useTsNode": true,
    "tsConfigPath": "./tsconfig.orm.json",
    "configPaths": [
      "./src/config/database/mikro-orm.config.ts",
      "./dist/src/config/database/mikro-orm.config.js",
      "./dist/config/database/mikro-orm.config.js"
    ]
  }
}
