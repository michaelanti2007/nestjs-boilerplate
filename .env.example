PORT=8080
NODE_ENV=development
SHOW_SWAGGER=true
RUN_MIGRATIONS_ON_BOOT=true
RUN_SEEDERS_ON_BOOT=false
API_KEY=change-me-api-key
JWT_SECRET=change-me-super-secret
JWT_EXPIRES_IN=3600
AUTH_DEMO_MODE=false
AUTH_DEMO_EMAIL=admin@example.com
AUTH_DEMO_PASSWORD=change-me
AUTH_DEMO_ROLES=admin
AUTH_DEMO_PERMISSIONS=app:read,app:manage

# Security / networking
TRUST_PROXY=false
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,x-api-key
CORS_CREDENTIALS=false

# Supported DB values: postgresql, postgres, pg, mysql, mariadb
# Command override examples:
# - npm run start:dev -- --db=mysql
# - npm run start:dev -- --db=postgres --schema=subscription
DB_CLIENT=postgresql

# Standard database connection values.
# For MySQL, set DB_CLIENT=mysql and typically use DB_PORT=3306 DB_USER=root.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=nestjs_boilerplate
DB_USER=postgres
DB_PASS=postgres
# Required when DB_CLIENT=postgresql
DB_SCHEMA=public
DB_SSL=false
DB_DEBUG=false

# Migration behavior
DB_MIGRATIONS_TABLE=mikro_orm_migrations
DB_MIGRATIONS_PATH=dist/migrations
DB_MIGRATIONS_PATH_TS=migrations
DB_VERIFY_MIGRATION_DIFF=false
# Optional comma-separated table allow-list for generated migration SQL
DB_MIGRATION_INCLUDED_TABLES=
# Optional comma-separated schema block-list for generated migration SQL
DB_MIGRATION_EXCLUDED_SCHEMAS=

# Redis / BullMQ (optional)
# Command override example: npm run start:dev -- --redis=on
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_USER=
REDIS_PASS=
QUEUE_GENERAL_NAME=general
QUEUE_JOB_REMOVE_ON_COMPLETE_AGE=3600
QUEUE_JOB_REMOVE_ON_FAIL_AGE=86400

# Throttle defaults (global guard)
THROTTLE_ENABLED=true
THROTTLE_DEFAULT_LIMIT=100
THROTTLE_DEFAULT_TTL_MS=60000
THROTTLE_USE_REDIS=true
# Development overrides (0 disables throttling in development mode)
THROTTLE_DEV_LIMIT=0
THROTTLE_DEV_TTL_MS=0

# Storage (local | s3)
# Command override example: npm run start:dev -- --storage=s3
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=storage-data
APP_BASE_URL=http://localhost:8080
ATTACHMENT_URL_SIGNING_SECRET=change-me-attachment-signing-secret
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Attachment upload constraints
ATTACHMENT_MAX_FILE_SIZE_BYTES=10485760
ATTACHMENT_ALLOWED_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/jpg,image/png,image/heic,image/heif
ATTACHMENT_UPLOAD_STORAGE=memory
ATTACHMENT_UPLOAD_TEMP_DIR=data/temp/uploads

# Mail (console | sendgrid | smtp | ses)
# Command override examples:
# - npm run start:dev -- --mail=smtp
# - npm run start:dev -- --mail=ses
MAIL_PROVIDER=console
MAIL_FROM_ADDRESS=no-reply@localhost
EMAIL_SOURCE=
MAIL_TEMPLATES_PATH=mail-templates
SENDGRID_API_KEY=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Proxy configuration
# JSON object with service keys and endpoint maps.
# Example:
# {"billing":{"baseUrl":"http://localhost:9000","endpoints":{"create":{"targetEndpoint":"/v1/payments"}}}}
PROXY_SERVICES_JSON={}
PROXY_ALLOW_BASE_URL_OVERRIDE=false
PROXY_ALLOW_DYNAMIC_CONFIG=false
PROXY_ALLOW_PRIVATE_IPS=false
PROXY_MAX_REDIRECTS=0
